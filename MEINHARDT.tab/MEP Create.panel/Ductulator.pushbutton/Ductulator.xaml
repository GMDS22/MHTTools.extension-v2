<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MHT Ductolator by GM"
        Width="1260"
        Height="820"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#EAECF0"
        Foreground="#1A202C">

    <Window.Resources>
        <!-- Primary button (Calculate) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1B3A6B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#254D8F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#122850"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (Reset, Help) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F4F8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90A4B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox — fixed margin on ScrollViewer so text is never clipped -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="8,0,8,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1B3A6B"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header -->
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Top header bar ── -->
        <Border Grid.Row="0" Background="#1B3A6B">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MHT DUCTULATOR" FontSize="14" FontWeight="Bold"
                               Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Border Width="1" Background="#3D5A8A" Margin="12,8"/>
                    <TextBlock Text="Duct Velocity Reference Tool" FontSize="11"
                               Foreground="#90B4D8" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="by GM · Meinhardt" FontSize="10"
                           Foreground="#5C7EA8" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main body ── -->
        <Grid Grid.Row="1" Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="282"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL ===== -->
            <Border Grid.Column="0" CornerRadius="8" Background="#F0F4F8"
                    BorderBrush="#DDE3EA" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- INPUTS sub-section -->
                    <Border Grid.Row="0" CornerRadius="6" Background="#FFFFFF"
                            BorderBrush="#C9D4DF" BorderThickness="1" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="INPUTS" FontSize="9" FontWeight="Bold"
                                       Foreground="#7A8FA8"/>

                            <TextBlock Grid.Row="2" Text="Airflow (L/s)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5568"/>
                            <TextBox x:Name="InpAirflow" Grid.Row="4" Style="{StaticResource InputBox}" Text="240"/>

                            <TextBlock Grid.Row="6" Text="Target Velocity (m/s)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5568"/>
                            <TextBox x:Name="InpVelocity" Grid.Row="8" Style="{StaticResource InputBox}" Text="4"/>

                            <TextBlock Grid.Row="10" Text="Known Duct Width (mm)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5568"/>
                            <TextBox x:Name="InpWidth" Grid.Row="12" Style="{StaticResource InputBox}" Text="250"/>

                            <TextBlock Grid.Row="14" Text="Duct Length (mm)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4A5568"
                                       ToolTip="Second cross-section dimension (duct height). Required for Pa/m Loss calculation."/>
                            <TextBox x:Name="InpDuctLength" Grid.Row="16" Style="{StaticResource InputBox}"
                                     ToolTip="Enter the duct height in mm to calculate Pa/m Loss (Darcy-Weisbach)"/>

                            <Grid Grid.Row="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Calculate"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="calculate_click"/>
                                <Button Grid.Column="2" Content="Reset"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="reset_click"/>
                                <Button Grid.Column="4" Content="?"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="help_click"
                                        ToolTip="How to use this tool"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- RESULTS sub-section -->
                    <Border Grid.Row="2" CornerRadius="6" Background="#FAFCFF"
                            BorderBrush="#C9D4DF" BorderThickness="1" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="RESULTS" FontSize="9" FontWeight="Bold"
                                       Foreground="#7A8FA8"/>

                            <!-- Flowrate card — blue -->
                            <Border Grid.Row="2" CornerRadius="6" Background="#EBF4FF"
                                    BorderBrush="#BEE3F8" BorderThickness="1" Padding="10,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="FLOWRATE" FontSize="9" FontWeight="Bold" Foreground="#2B6CB0"/>
                                        <TextBlock x:Name="TxtFlowrate" Text="864"
                                                   FontSize="20" FontWeight="Bold" Foreground="#1A365D"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="m³/h" FontSize="11"
                                               Foreground="#4299E1" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </Grid>
                            </Border>

                            <!-- Round Diameter card — teal -->
                            <Border Grid.Row="4" CornerRadius="6" Background="#E6FFFA"
                                    BorderBrush="#B2F5EA" BorderThickness="1" Padding="10,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="ROUND EQUIV. Ø" FontSize="9" FontWeight="Bold" Foreground="#276749"/>
                                        <TextBlock x:Name="TxtRoundDia" Text="276"
                                                   FontSize="20" FontWeight="Bold" Foreground="#1C4532"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="mm" FontSize="11"
                                               Foreground="#38A169" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </Grid>
                            </Border>

                            <!-- Rect Size card — purple -->
                            <Border Grid.Row="6" CornerRadius="6" Background="#FAF5FF"
                                    BorderBrush="#E9D8FD" BorderThickness="1" Padding="10,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RECT. SIZE (W × H)" FontSize="9" FontWeight="Bold" Foreground="#553C9A"/>
                                        <TextBlock x:Name="TxtRect" Text="250 x 250"
                                                   FontSize="18" FontWeight="Bold" Foreground="#322659"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="mm" FontSize="11"
                                               Foreground="#805AD5" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </Grid>
                            </Border>

                            <!-- Pa/m Loss card — amber/gold -->
                            <Border Grid.Row="8" CornerRadius="6" Background="#FFFBEB"
                                    BorderBrush="#F6E05E" BorderThickness="1" Padding="10,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Pa/m LOSS" FontSize="9" FontWeight="Bold" Foreground="#744210"
                                                   ToolTip="Friction pressure gradient — Darcy-Weisbach (Haaland). Requires Duct Width + Duct Length."/>
                                        <TextBlock x:Name="TxtPaPerM" Text="—"
                                                   FontSize="20" FontWeight="Bold" Foreground="#7B341E"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Pa/m" FontSize="11"
                                               Foreground="#D69E2E" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </Grid>
                            </Border>

                            <!-- Tip -->
                            <TextBlock Grid.Row="10"
                                       Text="Tip: Use the tables as a fast check against your design intent."
                                       Foreground="#A0AEC0" FontSize="9" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== RIGHT PANEL ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Active calculation header bar -->
                <Border Grid.Row="0" CornerRadius="8" Background="#FFFFFF"
                        BorderBrush="#DDE3EA" BorderThickness="1" Padding="12,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="3" Background="#EBF4FF" Padding="6,2" Margin="0,0,10,0">
                            <TextBlock Text="ACTIVE CALC" FontSize="9" FontWeight="Bold" Foreground="#2B6CB0"/>
                        </Border>
                        <TextBlock x:Name="TxtHeader"
                                   Text="Ductulator reference table view"
                                   FontWeight="SemiBold" FontSize="12" Foreground="#2D3748"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Row: Round duct + Legend (both equal * height with Rect row below) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Round duct table -->
                    <Border Grid.Column="0" CornerRadius="8" Background="#FFFFFF"
                            BorderBrush="#DDE3EA" BorderThickness="1" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <Border CornerRadius="3" Background="#EBF4FF" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="ROUND DUCT" FontSize="9" FontWeight="Bold" Foreground="#2B6CB0"/>
                                </Border>
                                <TextBlock Text="Velocity by diameter" FontSize="11"
                                           Foreground="#718096" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="RoundGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EDF2F7"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="{Binding BgColor}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Diameter (mm)" Binding="{Binding Diameter}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Foreground" Value="#2D3748"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Velocity (m/s)" Binding="{Binding Velocity}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Foreground" Value="#1A202C"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Legend (auto-sized DataGrid — no empty rows) -->
                    <Border Grid.Column="2" CornerRadius="8" Background="#FFFFFF"
                            BorderBrush="#DDE3EA" BorderThickness="1" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <Border CornerRadius="3" Background="#FAF5FF" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="LEGEND" FontSize="9" FontWeight="Bold" Foreground="#805AD5"/>
                                </Border>
                                <TextBlock Text="m/s bands" FontSize="11"
                                           Foreground="#718096" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="LegendGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#EDF2F7"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="{Binding BgColor}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Foreground" Value="#1A202C"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Foreground" Value="#2D3748"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Rectangular duct table (same * height as the Round+Legend row) -->
                <Border Grid.Row="4" CornerRadius="8" Background="#FFFFFF"
                        BorderBrush="#DDE3EA" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Border CornerRadius="3" Background="#FFF5F5" Padding="6,2" Margin="0,0,8,0">
                                <TextBlock Text="RECTANGULAR DUCT" FontSize="9" FontWeight="Bold" Foreground="#C53030"/>
                            </Border>
                            <TextBlock Text="Velocity (m/s) · Height rows × Width columns"
                                       FontSize="11" Foreground="#718096" VerticalAlignment="Center"/>
                        </StackPanel>
                        <DataGrid x:Name="SquareGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="True"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  FrozenColumnCount="1"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EDF2F7"
                                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
