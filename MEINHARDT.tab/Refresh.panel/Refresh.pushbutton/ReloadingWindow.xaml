<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True">
  <Window.Resources>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0E639C"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#1FA6A6"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#F2B134"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#E81A1A1C"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#553A3A40"/>

    <Storyboard x:Key="RotateRingStoryboard" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="RingRotate"
                       Storyboard.TargetProperty="Angle"
                       From="0" To="360"
                       Duration="0:0:2.0"/>
    </Storyboard>

    <Storyboard x:Key="PulseCenterStoryboard" RepeatBehavior="Forever" AutoReverse="True">
      <DoubleAnimation Storyboard.TargetName="CenterBadgeScale"
                       Storyboard.TargetProperty="ScaleX"
                       From="1.0" To="1.08"
                       Duration="0:0:0.8"/>
      <DoubleAnimation Storyboard.TargetName="CenterBadgeScale"
                       Storyboard.TargetProperty="ScaleY"
                       From="1.0" To="1.08"
                       Duration="0:0:0.8"/>
      <DoubleAnimation Storyboard.TargetName="CenterBadge"
                       Storyboard.TargetProperty="Opacity"
                       From="0.9" To="1.0"
                       Duration="0:0:0.8"/>
    </Storyboard>

    <Storyboard x:Key="OrbitStoryboard" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="OrbitRotate"
                       Storyboard.TargetProperty="Angle"
                       From="360" To="0"
                       Duration="0:0:1.6"/>
    </Storyboard>
  </Window.Resources>

  <Window.Triggers>
    <EventTrigger RoutedEvent="Window.Loaded">
      <BeginStoryboard Storyboard="{StaticResource RotateRingStoryboard}"/>
      <BeginStoryboard Storyboard="{StaticResource PulseCenterStoryboard}"/>
      <BeginStoryboard Storyboard="{StaticResource OrbitStoryboard}"/>
    </EventTrigger>
  </Window.Triggers>

  <Border Background="{StaticResource SurfaceBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="14"
          Padding="18">
    <Grid Width="360" Height="190">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Ellipse Width="94" Height="94" Stroke="#3322B8B8" StrokeThickness="2"/>
        <Ellipse Width="94" Height="94" Stroke="#99F2B134" StrokeThickness="3" StrokeDashArray="5,7">
          <Ellipse.RenderTransform>
            <RotateTransform x:Name="RingRotate" CenterX="47" CenterY="47"/>
          </Ellipse.RenderTransform>
        </Ellipse>

        <Canvas Width="120" Height="120">
          <Canvas.RenderTransform>
            <RotateTransform x:Name="OrbitRotate" CenterX="60" CenterY="60"/>
          </Canvas.RenderTransform>
          <Ellipse Width="10" Height="10" Fill="{StaticResource SecondaryBrush}" Canvas.Left="55" Canvas.Top="4"/>
          <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Canvas.Left="106" Canvas.Top="55"/>
          <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" Canvas.Left="7" Canvas.Top="55"/>
        </Canvas>

        <Border x:Name="CenterBadge"
                Width="62"
                Height="62"
                CornerRadius="31"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="#991177BB"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Border.RenderTransform>
            <ScaleTransform x:Name="CenterBadgeScale" CenterX="31" CenterY="31"/>
          </Border.RenderTransform>
          <TextBlock Text="MHT"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontWeight="Bold"
                     FontSize="16"
                     Foreground="White"/>
        </Border>
      </Grid>

      <TextBlock Grid.Row="1"
                 Margin="0,6,0,0"
                 Text="Refreshing Meinhardt Tools"
                 FontWeight="SemiBold"
                 FontSize="15"
                 Foreground="#E8E8E8"
                 HorizontalAlignment="Center"/>
      <TextBlock Grid.Row="2"
                 Margin="0,4,0,0"
                 Text="Applying updates to current pyRevit session..."
                 FontSize="12"
                 Foreground="#B8B8C0"
                 HorizontalAlignment="Center"/>
    </Grid>
  </Border>
</Window>
