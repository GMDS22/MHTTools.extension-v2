<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Legend Creator"
        Height="560"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Legend Title" Margin="0,0,0,4" />
                <TextBox x:Name="txtLegendTitle" Margin="0,0,0,10" />

                <TextBlock Text="Mode" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbMode" SelectionChanged="mode_changed" Margin="0,0,0,10" />

                <TextBlock Text="Target" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbTarget" Margin="0,0,0,10" />

                <TextBlock Text="Content" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbUsed" Margin="0,0,0,10" />

                <TextBlock Text="Text Style" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbTextStyle" Margin="0,0,0,10" />

                <StackPanel x:Name="rowCategory" Margin="0,0,0,10">
                    <TextBlock Text="Category (Single-Category Family Legend)" Margin="0,0,0,4" />
                    <ComboBox x:Name="cmbCategory" />
                </StackPanel>

                <StackPanel x:Name="rowScheme" Margin="0,0,0,10">
                    <TextBlock Text="Color Fill Scheme" Margin="0,0,0,4" />
                    <ComboBox x:Name="cmbScheme" />
                </StackPanel>

                <StackPanel x:Name="rowBoxW" Margin="0,0,0,10">
                    <TextBlock Text="Box Width [mm]" Margin="0,0,0,4" />
                    <TextBox x:Name="txtBoxW" />
                </StackPanel>

                <StackPanel x:Name="rowBoxH" Margin="0,0,0,10">
                    <TextBlock Text="Box Height [mm]" Margin="0,0,0,4" />
                    <TextBox x:Name="txtBoxH" />
                </StackPanel>

                <StackPanel x:Name="rowBoxOff" Margin="0,0,0,10">
                    <TextBlock Text="Offset [mm]" Margin="0,0,0,4" />
                    <TextBox x:Name="txtBoxOff" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Create" Width="90" Margin="0,0,8,0" Click="create_click" />
            <Button Content="Cancel" Width="90" Click="cancel_click" />
        </StackPanel>
    </Grid>
</Window>
