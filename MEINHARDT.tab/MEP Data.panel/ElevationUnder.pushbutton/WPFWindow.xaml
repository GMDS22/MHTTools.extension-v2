<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compute elevation under floor or roof" MaxHeight="1000 px" MinWidth="200" ShowInTaskbar="True" Topmost="False"
        WindowStartupLocation="Manual" Left="400" Top="400" SizeToContent="WidthAndHeight" HorizontalContentAlignment="Center"
        Background="#1A1A1C" Foreground="#E8E8E8">
    <Window.Resources>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#1FA6A6"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#22B8B8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A40"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#232327"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E22"/>

        <Style TargetType="StackPanel">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="buttonStyle" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <StackPanel>
        <StackPanel Margin="10">
            <Button Click="compute_selected_click"
                    Style="{StaticResource buttonStyle}">
                Compute selected
            </Button>
        </StackPanel>
        <StackPanel Margin="10">
            <TextBlock>Storage parameter</TextBlock>
            <TextBox x:Name="tbx_parameter_name"/>
        </StackPanel>
        <StackPanel Margin="10">
            <TextBlock>Currently selected 3D view :</TextBlock>
            <TextBlock x:Name="tbk_view3d"/>
            <Button Click="select_view3d_click"
                    Style="{StaticResource buttonStyle}">
                Select 3D view
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
