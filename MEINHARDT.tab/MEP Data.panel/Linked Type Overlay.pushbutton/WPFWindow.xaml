<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linked Type Overlay by GM"
        Height="840"
        Width="1180"
        MinWidth="980"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1A1A1C"
        Foreground="#E8E8E8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#232327"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#2A2A2E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A40"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0E639C"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1177BB"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#1FA6A6"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#22B8B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F2B134"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#D99A20"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8A8A9A"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF7D"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="StepNum" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="ListLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="#3A3A40"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#505058"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryAction" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SecondaryAction" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="AccentAction" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#101114"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
        </Style>
        <ControlTemplate x:Key="DarkComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="BtnBorder"
                    Background="#2A2A2E"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="22"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1"
                            Background="#33333A"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,0,0,0"/>
                    <Path Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Fill="#E8E8E8"
                          Data="M 0 0 L 4 4 L 8 0 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="BtnBorder" Property="Background" Value="#303036"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="BtnBorder" Property="Background" Value="#303036"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.65"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="2"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Template="{StaticResource DarkComboBoxToggleButtonTemplate}"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Margin="8,2,28,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E8E8E8"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1E1E22"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#252528"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0E639C"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="ComboBoxItemTemplate">
            <TextBlock Text="{Binding}" Foreground="#E8E8E8" TextWrapping="NoWrap"/>
        </DataTemplate>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="RowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="#1E1E22"/>
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#232327"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,12,14,14">
            <TextBlock Text="Linked Type Overlay"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#E8E8E8"
                       Margin="0,0,0,2"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="Follow steps 1 → 2 → 3 → 4 in order, then click Create Overlay."
                       Margin="0,0,0,10"/>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Style="{StaticResource StepBadge}">
                            <TextBlock Style="{StaticResource StepNum}" Text="1"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Style="{StaticResource StepTitle}" Text="Select Linked Element Types"/>
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="Choose the linked architectural model, search the linked element types, tick the source types you want to show, or pick linked source elements directly from the current view."/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource ListLabel}" Text="Source Input Mode"/>
                        <ComboBox x:Name="cmbSourceInputMode"
                                  Height="28"
                                  SelectionChanged="source_input_mode_changed"
                                  ToolTip="Choose whether Step 1 shows source-type search or direct picking from the current view.">
                            <ComboBoxItem Content="Find Source Element Types"/>
                            <ComboBoxItem Content="Pick from Current View"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource ListLabel}" Text="Active Linked Model (auto from picked element)"/>
                        <Border Background="#1E1E22"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8,5"
                                Margin="0,0,0,6">
                            <TextBlock x:Name="txtActiveLinkInfo"
                                       Style="{StaticResource InfoValue}"
                                       Text="No active linked model yet. Click Pick from Current View to set it automatically."
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="pnlFindSourceTypes" DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource ListLabel}" Text="Find Source Element Types"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtSourceSearch"
                                     Width="260"
                                     TextChanged="source_search_changed"
                                     ToolTip="Type part of a category, family, or type name to filter the linked element type list."/>
                            <Button Content="All"
                                    Click="select_all_source_types_click"
                                    MinWidth="44"
                                    ToolTip="Check all linked element types currently shown in the filtered list."/>
                            <Button Content="None"
                                    Click="deselect_all_source_types_click"
                                    MinWidth="52"
                                    ToolTip="Clear all linked element type selections."/>
                            <Button Content="Refresh"
                                    Click="refresh_source_types_click"
                                    MinWidth="68"
                                    ToolTip="Rescan source element types from the current active linked model context."/>
                        </StackPanel>

                        <ListBox x:Name="lstSourceTypes"
                                 Height="220"
                                 AlternationCount="2"
                                 ItemContainerStyle="{StaticResource RowStyle}"
                                 ToolTip="Tick one or more linked element types to analyze and overlay."/>

                        <Border Background="#1E1E22"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8,6"
                                Margin="0,8,0,0">
                            <TextBlock x:Name="txtSourceSummary"
                                       Style="{StaticResource InfoValue}"
                                       Text="No linked element types selected yet."
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="pnlPickSourceElements" DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource ListLabel}" Text="Pick Linked Source Elements"/>
                        <Button Content="Pick from Current View"
                                Click="pick_source_elements_click"
                                MinWidth="142"
                                Margin="0"
                                ToolTip="Pick linked source elements from the current view; this automatically sets the active linked model and checks matching source types."/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Use this mode when you want to select linked elements directly instead of searching the source-type list."/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Style="{StaticResource StepBadge}">
                            <TextBlock Style="{StaticResource StepNum}" Text="2"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Style="{StaticResource StepTitle}" Text="Select Host Plan Views"/>
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="Tick the host plan views that should receive the linked overlay output. The active plan is preselected when possible, and the quick option can switch between the active view only or the current checked view set."/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="txtViewSearch"
                                 Width="260"
                                 TextChanged="view_search_changed"
                                 ToolTip="Type part of a view name, level, or view type to filter the host plan list."/>
                        <Button Content="All"
                                Click="select_all_views_click"
                                MinWidth="44"
                                ToolTip="Check all views currently shown in the filtered list."/>
                        <Button Content="None"
                                Click="deselect_all_views_click"
                                MinWidth="52"
                                ToolTip="Clear all checked host views."/>
                        <Button Content="Active"
                                Click="use_active_view_click"
                                MinWidth="56"
                            ToolTip="Keep only the current active host plan view checked."/>
                        <ComboBox x:Name="cmbQuickViewMode"
                              Width="190"
                              SelectedIndex="0"
                              ToolTip="Choose whether the quick selector should keep the active host view or preserve the current checked view set.">
                            <ComboBoxItem Content="Active View Only"/>
                            <ComboBoxItem Content="Keep Current Checked Views"/>
                        </ComboBox>
                        <Button Content="Apply View Option"
                            Click="apply_view_option_click"
                            MinWidth="122"
                                Margin="0"
                            ToolTip="Apply the quick view option selected in the dropdown."/>
                    </StackPanel>

                    <ListBox x:Name="lstPlanViews"
                             Height="220"
                             AlternationCount="2"
                             ItemContainerStyle="{StaticResource RowStyle}"
                             ToolTip="Tick the plan views that should be scanned for matching linked element locations."/>

                    <Border DockPanel.Dock="Bottom"
                            Background="#1E1E22"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8,6"
                            Margin="0,8,0,0">
                        <TextBlock x:Name="txtViewSummary"
                                   Style="{StaticResource InfoValue}"
                                   Text="No host plan views selected yet."
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </Border>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Style="{StaticResource StepBadge}">
                            <TextBlock Style="{StaticResource StepNum}" Text="3"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Style="{StaticResource StepTitle}" Text="Choose Overlay Output"/>
                            <TextBlock Style="{StaticResource Hint}"
                                       Text="Pick whether the overlay should create host family instances, detail items, generic annotations, linked tags, or text notes. View-based detail items and generic annotations are included in the supported host-family list when available."/>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Style="{StaticResource ListLabel}" Text="Output Mode"/>
                            <ComboBox x:Name="cmbOutputMode"
                                      Height="28"
                                      ItemTemplate="{StaticResource ComboBoxItemTemplate}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      SelectionChanged="output_mode_changed"
                                      ToolTip="Choose the type of overlay object to create at the linked element locations.">
                                <ComboBoxItem Content="Place Host Family Type"/>
                                <ComboBoxItem Content="Create Tags"/>
                                <ComboBoxItem Content="Create Text Notes"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel x:Name="pnlHostFamilyType" Grid.Row="0" Grid.Column="2">
                            <TextBlock Style="{StaticResource ListLabel}" Text="Supported Host Family Type / Detail Item / Annotation"/>
                            <ComboBox x:Name="cmbHostFamilyType"
                                      Height="28"
                                      ItemTemplate="{StaticResource ComboBoxItemTemplate}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Choose the host family type to place. Supported placement types are view-based and one-level-based, including loaded detail items and generic annotations when supported by Revit."/>
                        </StackPanel>

                        <StackPanel x:Name="pnlTagType" Grid.Row="1" Grid.Column="0" Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource ListLabel}" Text="Tag Type"/>
                            <ComboBox x:Name="cmbTagType"
                                      Height="28"
                                      ItemTemplate="{StaticResource ComboBoxItemTemplate}"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Choose the tag family type to use when creating linked-element tags. Use a tag compatible with the linked source category."/>
                        </StackPanel>

                        <StackPanel x:Name="pnlTextType" Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource ListLabel}" Text="Text Note Type"/>
                            <ComboBox x:Name="cmbTextType"
                                      Height="28"
                                                                            ItemTemplate="{StaticResource ComboBoxItemTemplate}"
                                                                            ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                      ToolTip="Choose the text note type to use when placing note markers at the linked element locations."/>
                        </StackPanel>

                        <StackPanel x:Name="pnlTextNoteContent" Grid.Row="2" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                                        <TextBlock Style="{StaticResource ListLabel}" Text="Text Note Content"/>
                            <TextBox x:Name="txtNoteFormat"
                                                                         ToolTip="Used only for text-note output. Type the exact text you want placed in the note."/>
                            <TextBlock Style="{StaticResource Hint}"
                                                                             Text="Example: Located equipment / specialty item."/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                            <CheckBox x:Name="chkSkipDuplicates"
                                      Content="Skip nearby duplicates"
                                      IsChecked="True"
                                      ToolTip="When enabled, the tool skips a new family, tag, or note if the same output is already placed very close to the linked point."/>
                            <CheckBox x:Name="chkAnalyzeBeforeCreate"
                                      Content="Always re-run analysis before create"
                                      IsChecked="True"
                                      ToolTip="When enabled, Create Overlay refreshes the checked-view match analysis before placing anything."/>
                        </StackPanel>

                        <Border Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Background="#1E1E22"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8,6"
                                Margin="0,8,0,0">
                            <TextBlock x:Name="txtOutputSummary"
                                       Style="{StaticResource InfoValue}"
                                       Text="Choose an output mode, then analyze the checked views."
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StepBadge}">
                        <TextBlock Style="{StaticResource StepNum}" Text="4"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="8,0,16,0">
                        <TextBlock Style="{StaticResource StepTitle}" Text="Analyze Then Create"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Analyze counts the matching linked instances in the checked host plans. Create Overlay then places the selected output at those locations."/>
                        <Border Background="#1E1E22"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10,8"
                                Margin="0,8,0,0">
                            <TextBlock x:Name="txtRunSummary"
                                       Style="{StaticResource InfoValue}"
                                       Text="No analysis has run yet."
                                       Foreground="{StaticResource MutedTextBrush}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Analyze Checked Views"
                                Click="analyze_click"
                                Style="{StaticResource SecondaryAction}"
                                Padding="18,8"
                                ToolTip="Preview how many matching linked source instances are found in each checked host plan view."/>
                        <Button Content="Create Overlay"
                                Click="create_overlay_click"
                                Style="{StaticResource AccentAction}"
                                Padding="18,8"
                                ToolTip="Create the selected output at every analyzed linked element location in the checked plan views."/>
                        <Button Content="Cancel"
                                Click="cancel_click"
                                Padding="18,8"
                                Margin="0"
                                ToolTip="Close the tool without creating anything."/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>