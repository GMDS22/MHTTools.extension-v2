<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select reference level:" SizeToContent="WidthAndHeight" ShowInTaskbar="False" Topmost="True"
        WindowStartupLocation="CenterScreen" Left="0" Top="180" ScrollViewer.VerticalScrollBarVisibility="Disabled" HorizontalContentAlignment="Center"
        Background="#1A1A1C" Foreground="#E8E8E8">
        <Window.Resources>
            <SolidColorBrush x:Key="PrimaryBrush" Color="#0E639C"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1177BB"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="#1FA6A6"/>
            <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#22B8B8"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#3A3A40"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#232327"/>
            <SolidColorBrush x:Key="InputBrush" Color="#1E1E22"/>

            <Style TargetType="GroupBox">
                <Setter Property="Foreground" Value="#E8E8E8"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Padding" Value="6"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource InputBrush}"/>
                <Setter Property="Foreground" Value="#E8E8E8"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="4,0,0,0"/>
            </Style>
            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
            </Style>
        </Window.Resources>
        <StackPanel Margin="10" HorizontalAlignment="Stretch">
            <GroupBox Header="From levels list" Margin="0,0,10,0">
                <StackPanel Margin="10" Orientation="Horizontal">
                    <ComboBox x:Name="combobox_levels" ItemsSource="{Binding}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding Name}" IsEditable="True"
                              MinWidth="100" Padding="5">
                    </ComboBox>
                    <Button x:Name="button_levelfromlist" Content="Ok" Click="from_list_click" HorizontalAlignment="Center" Padding="5" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="From a reference object" Margin="0,0,10,0">
                <StackPanel Margin="10">
                    <Button Content="Select an object" Click="from_object_click" HorizontalAlignment="Left" Padding="5"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
</Window>
