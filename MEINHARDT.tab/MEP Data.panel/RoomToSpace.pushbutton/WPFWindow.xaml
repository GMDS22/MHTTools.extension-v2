<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoomToSpace" MaxHeight="1000 px" Width="Auto" ShowInTaskbar="True" Topmost="False"
        WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" HorizontalContentAlignment="Center" Closed="window_closed"
        Background="#1A1A1C" Foreground="#E8E8E8">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0E639C"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1177BB"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#1FA6A6"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#22B8B8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A40"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#232327"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E22"/>

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="buttonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}"/>
        </Style>
    </Window.Resources>
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <GroupBox Header="Room">
                <StackPanel>
                    <TextBlock Margin="5"><Bold>Pick Source Project</Bold></TextBlock>
                    <ComboBox x:Name="source_project" 
                              ItemsSource="{Binding}" DisplayMemberPath="Title"
                              SelectedValuePath="Title" SelectedValue="{Binding Title, Mode=OneWay}"/>
                    <TextBlock Margin="5">
                        <Bold>Enter source parameters or text separated with tab</Bold><LineBreak />
                        Every source on a single line will be concatenated :<LineBreak />
                        %room_parameter1_name |TAB| %separator |TAB| %room_parameter2…<LineBreak />
                        Examples:<LineBreak />
                        Number |TAB| - |TAB| CustomParameterName<LineBreak />
                        Name<LineBreak />
                        Comments |TAB| _ |TAB| CustomParameterName
                    </TextBlock>
                    <TextBox x:Name="source_parameters" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Space">
                <StackPanel>
                    <TextBlock Margin="5"><Bold>Target Project</Bold></TextBlock>
                    <ComboBox x:Name="target_project" 
                              ItemsSource="{Binding}" DisplayMemberPath="Title"
                              SelectedValuePath="Title" SelectedValue="{Binding Title, Mode=OneWay}"/>
                    <TextBlock Margin="5">
                        <Bold>Enter target parameters.</Bold><LineBreak />
                        One per line corresponding to each source line :<LineBreak />
                        %space_parameter1_name<LineBreak />
                        Examples:<LineBreak />
                        Number<LineBreak />
                        Name<LineBreak />
                        Comments
                    </TextBlock>
                    <TextBox x:Name="target_parameters" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        <Button Content="Ok" Click="ok_click" IsDefault="True" Width="100" Margin="5"/>
    </StackPanel>
</Window>
