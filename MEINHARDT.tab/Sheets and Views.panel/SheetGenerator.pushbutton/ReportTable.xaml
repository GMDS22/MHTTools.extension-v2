<Window Title="MHT Sheet Generator Report"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="400" Width="500" WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="#1c1c1c" AllowsTransparency="True"
        BorderBrush="#ff9a2e" BorderThickness="1" CornerRadius="10">

    <Window.Resources>
        <SolidColorBrush x:Key="accent" Color="#ff9a2e"/>
        <SolidColorBrush x:Key="white" Color="#f2f2f2"/>
        <SolidColorBrush x:Key="bg1" Color="#1c1c1c"/>
        <SolidColorBrush x:Key="bg2" Color="#2b2b2b"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Header-->
        <Border Grid.Row="0" Background="#2c2c2c" CornerRadius="10,10,0,0">
            <Grid>
                <TextBlock Text="Generated Sheets & Views" Foreground="#f2f2f2" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                <Button Content="X" Width="30" Height="30" HorizontalAlignment="Right" Margin="0,0,10,0" Background="#1c1c1c" Foreground="White" BorderBrush="#ff9a2e" Click="UIe_close"/>
            </Grid>
        </Border>

        <!--Content-->
        <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel x:Name="UI_main_stack" Background="#2b2b2b"/>
        </ScrollViewer>
    </Grid>
</Window>