<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Views Links Manager"
    Height="720" Width="1260"
    MinHeight="560" MinWidth="980"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="True"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="Transparent"
    AllowsTransparency="True"
    UseLayoutRounding="True"
    Loaded="window_loaded">

    <Window.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="accent" Color="#0f5ea8"/>
            <SolidColorBrush x:Key="hover" Color="#1e75c1"/>
            <SolidColorBrush x:Key="bg1" Color="#0b1a2b"/>
            <SolidColorBrush x:Key="bg2" Color="#10243a"/>
            <SolidColorBrush x:Key="bg3" Color="#0d2035"/>
            <SolidColorBrush x:Key="header_background" Color="#12304a"/>
            <SolidColorBrush x:Key="panel_separator" Color="#1a3a58"/>
            <SolidColorBrush x:Key="text_white" Color="#f2f2f2"/>
            <SolidColorBrush x:Key="text_cyan" Color="#9ad7ff"/>
            <SolidColorBrush x:Key="text_dim" Color="#6a8fa8"/>
            <SolidColorBrush x:Key="border_secondary" Color="#0f5ea8"/>
            <SolidColorBrush x:Key="border_panel" Color="#1a3a58"/>
            <SolidColorBrush x:Key="field_bg" Color="#eef2d6"/>
            <SolidColorBrush x:Key="field_text" Color="#111111"/>

            <Style TargetType="Button">
                <Setter Property="TextElement.FontFamily" Value="Arial"/>
                <Setter Property="Background" Value="#0b1a2b"/>
                <Setter Property="BorderBrush" Value="{StaticResource accent}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource text_white}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource hover}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.45"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource accent}"/>
                <Setter Property="BorderBrush" Value="{StaticResource hover}"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                <Border x:Name="Box"
                                        Width="16" Height="16"
                                        Margin="0,0,6,0"
                                        CornerRadius="2"
                                        Background="#0b1a2b"
                                        BorderBrush="#8fbde4"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="Glyph"
                                               Text="✔"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                            </DockPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Box" Property="Background" Value="#0f5ea8"/>
                                    <Setter TargetName="Box" Property="BorderBrush" Value="#5fc4ff"/>
                                    <Setter TargetName="Glyph" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="#5fc4ff"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource field_bg}"/>
                <Setter Property="Foreground" Value="{StaticResource field_text}"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="Padding" Value="6,3"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="TextElement.FontFamily" Value="Arial"/>
                <Setter Property="Background" Value="{StaticResource field_bg}"/>
                <Setter Property="Foreground" Value="{StaticResource field_text}"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="MaxDropDownHeight" Value="320"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="IsEditable" Value="False"/>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{StaticResource field_bg}"/>
                <Setter Property="Foreground" Value="{StaticResource field_text}"/>
                <Setter Property="Padding" Value="6,3"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0f5ea8"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#1e75c1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TreeView">
                <Setter Property="Background" Value="#0b1a2b"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style TargetType="ListBox">
                <Setter Property="Background" Value="#0b1a2b"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource border_secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="4,2"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1a3a58"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" Background="{StaticResource bg1}"
            BorderBrush="{StaticResource accent}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource header_background}"
                  PreviewMouseLeftButtonDown="header_drag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="MHT Tools" Foreground="{StaticResource text_white}" FontWeight="Bold" FontSize="13"/>
                    <TextBlock Text="  |  Views Links Manager"
                               Foreground="{StaticResource text_cyan}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <TextBlock Grid.Column="1" x:Name="UI_header_mode"
                           Foreground="{StaticResource text_dim}" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,12,0"
                           Text="Sheets: 0 | Views: 0 | Links: 0"/>

                <Button Grid.Column="2" Content="_" Width="28" Height="20"
                        FontSize="12" Click="button_minimize"
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="3" x:Name="UI_btn_maximize" Content="[]" Width="28" Height="20"
                        FontSize="10" Click="button_maximize"
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="4" Content="Close" Width="55" Height="20"
                        FontSize="10" Click="button_close"
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="UI_col_panel_1" Width="1.05*" MinWidth="260"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="UI_col_panel_2" Width="1.55*" MinWidth="360"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition x:Name="UI_col_panel_3" Width="1.2*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="8,8,4,8"
                        Background="{StaticResource bg2}"
                        BorderBrush="{StaticResource border_panel}"
                        BorderThickness="1" CornerRadius="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0"
                                  Padding="0">
                    <DockPanel Margin="10">
                        <TextBlock DockPanel.Dock="Top" Text="SETTINGS"
                                   Foreground="{StaticResource text_cyan}"
                                   FontWeight="Bold" FontSize="11"
                                   Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" Text="Template Policy"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_template_policy" Height="26" Margin="0,0,0,6"/>

                        <CheckBox DockPanel.Dock="Top" x:Name="UI_release_rvt_links_from_templates"
                                  Content="Release RVT Links from assigned templates on selected views before editing"
                                  Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" Text="Display Settings"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_display_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="display_mode_changed"/>

                        <TextBlock DockPanel.Dock="Top" x:Name="UI_reference_link_label" Text="Reference link"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_reference_link" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="reference_link_changed"/>

                        <TextBlock DockPanel.Dock="Top" x:Name="UI_linked_view_label" Text="Linked view from reference link"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_linked_view" Height="26" Margin="0,0,0,6"/>

                        <CheckBox DockPanel.Dock="Top" x:Name="UI_adapt_level_views"
                                  Content="Adapt selected linked view to matching level plans"
                                  IsChecked="True"
                                  Margin="0,0,0,6"/>

                        <CheckBox DockPanel.Dock="Top" x:Name="UI_freeze_to_custom"
                                  Content="After applying By linked view, switch Display Settings to Custom"
                                  Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" Text="Halftone"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_halftone_mode" Height="26" Margin="0,0,0,6"/>

                        <TextBlock DockPanel.Dock="Top" Text="Visibility"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_link_visibility_mode" Height="26" Margin="0,0,0,6"/>

                        <TextBlock DockPanel.Dock="Top" Text="Grid Action"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_grid_action" Height="26" Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" Text="CUSTOM LINK CONTROLS"
                                   Foreground="{StaticResource text_cyan}"
                                   FontWeight="Bold" FontSize="10" Margin="0,8,0,6"/>

                        <TextBlock DockPanel.Dock="Top" Text="Model / Annotation / Import Categories"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_object_styles_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="View Filters"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_view_filters_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="View Range"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_view_range_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Nested Links"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_nested_links_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Color Fill"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_color_fill_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Underlay"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_underlay_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Worksets"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_worksets_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Discipline"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_discipline_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Detail Level"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_detail_level_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>

                        <TextBlock DockPanel.Dock="Top" Text="Phase"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_phase_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_phase_choice" Height="26" Margin="0,0,0,6"/>

                        <TextBlock DockPanel.Dock="Top" Text="Phase Filter"
                                   Foreground="{StaticResource text_cyan}" FontSize="10" Margin="0,4,0,3"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_phase_filter_mode" Height="26" Margin="0,0,0,6"
                                  SelectionChanged="custom_setting_changed"/>
                        <ComboBox DockPanel.Dock="Top" x:Name="UI_phase_filter_choice" Height="26" Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" x:Name="UI_custom_settings_note"
                                   Foreground="{StaticResource text_dim}" FontSize="10"
                                   Text="These controls apply only when Display Settings is Custom. Worksets and Underlay are included only if this Revit build exposes those linked APIs; otherwise they will be reported in the log and skipped."
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <TextBlock DockPanel.Dock="Top" x:Name="UI_info_summary"
                                   Foreground="#9ad7ff" FontSize="11"
                                   Text="Select sheets, confirm views, then choose links to edit."
                                   TextWrapping="Wrap" Margin="0,4,0,8"/>

                        <Button DockPanel.Dock="Top" x:Name="UI_btn_apply" Content="Apply To Selected Views"
                                Height="30" Style="{StaticResource AccentButton}"
                                Click="button_apply" Margin="0,4,0,0"/>

                        <Button DockPanel.Dock="Top" x:Name="UI_btn_apply_typical"
                            Content="Typical Sheet Format"
                            Height="28" Click="button_apply_typical_format" Margin="0,6,0,0"/>

                        <Button DockPanel.Dock="Top" Content="Refresh Context"
                                Height="28" Click="button_refresh_context" Margin="0,6,0,0"/>

                        <Button DockPanel.Dock="Top" Content="Reset Panel Layout"
                                Height="28" Click="button_reset_layout" Margin="0,6,0,0"/>

                        <TextBlock DockPanel.Dock="Top" x:Name="UI_grid_note"
                                   Foreground="{StaticResource text_dim}" FontSize="10"
                                   Text="Recommended arch workflow: select the architectural links, choose one architectural link as the reference link, pick the linked plan that already shows room names, keep level adaptation on, then enable the helper above to freeze the result to Custom. The tool will try to map that selected linked view to the matching level plans across the selected sheets."
                                   TextWrapping="Wrap" Margin="0,10,0,0"/>

                        <Grid/>
                    </DockPanel>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource panel_separator}"
                              Cursor="SizeWE"
                              DragCompleted="panel_splitter_drag_completed"/>

                <Border Grid.Column="2" Margin="4,8,4,8"
                        Background="{StaticResource bg2}"
                        BorderBrush="{StaticResource border_panel}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2.3*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.6*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="SHEETS AND VIEWS"
                                       Foreground="{StaticResource text_cyan}"
                                       FontWeight="Bold" FontSize="11"/>
                            <TextBlock x:Name="UI_sheet_count"
                                       Foreground="White" FontSize="11" Margin="8,0,0,0"
                                       Text="(0 selected)"/>
                        </DockPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,6">
                            <TextBox x:Name="UI_search" Height="26" Width="240"
                                     ToolTip="Filter sheets by number, name, or group"
                                     TextChanged="search_textbox_changed"/>
                            <Button Content="Clear" Width="52" Height="24" Margin="6,0,0,0"
                                    Click="button_clear_search"/>
                        </DockPanel>

                        <Border Grid.Row="2" BorderBrush="{StaticResource border_secondary}"
                                BorderThickness="1" CornerRadius="4">
                            <TreeView x:Name="UI_tree_sheets"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Grid>
                                            <CheckBox x:Name="SheetCheck"
                                                      Content="{Binding Name}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Tag="{Binding}"
                                                      Click="sheet_checkbox_click"
                                                      Foreground="White"
                                                      Visibility="Collapsed"/>
                                            <CheckBox x:Name="GroupCheck"
                                                      Content="{Binding Name}"
                                                      IsChecked="{Binding GroupCheckState}"
                                                      IsThreeState="True"
                                                      Tag="{Binding}"
                                                      Click="sheet_checkbox_click"
                                                      FontWeight="SemiBold"
                                                      Foreground="#9ad7ff"
                                                      Visibility="Visible"/>
                                        </Grid>
                                        <HierarchicalDataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSheet}" Value="True">
                                                <Setter TargetName="SheetCheck" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="GroupCheck" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </HierarchicalDataTemplate.Triggers>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <DockPanel Grid.Row="3" Margin="0,8,0,0">
                            <Button Content="Check Shown" Width="90" Height="24" Click="button_check_all_sheets"/>
                            <Button Content="Uncheck Shown" Width="102" Height="24" Margin="6,0,0,0" Click="button_uncheck_all_sheets"/>
                            <Button Content="Invert Shown" Width="92" Height="24" Margin="6,0,0,0" Click="button_invert_shown_sheets"/>
                            <Button Content="Expand" Width="62" Height="24" Margin="6,0,0,0" Click="button_expand_all"/>
                            <Button Content="Collapse" Width="68" Height="24" Margin="6,0,0,0" Click="button_collapse_all"/>
                        </DockPanel>

                        <DockPanel Grid.Row="4" Margin="0,10,0,6">
                            <TextBlock Text="PLACED VIEWS ON SELECTED SHEETS"
                                       Foreground="{StaticResource text_cyan}"
                                       FontWeight="Bold" FontSize="10"/>
                            <TextBlock x:Name="UI_view_count"
                                       Foreground="White" FontSize="11" Margin="8,0,0,0"
                                       Text="(0 selected)"/>
                        </DockPanel>

                        <Grid Grid.Row="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBox x:Name="UI_view_filter" Height="26" Width="240"
                                         ToolTip="Filter views by sheet, view name, or level"
                                         TextChanged="view_filter_text_changed"/>
                            </DockPanel>

                            <ListBox Grid.Row="1" x:Name="UI_view_list">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  Tag="{Binding}"
                                                  Click="view_checkbox_click"
                                                  Margin="2,1,2,1">
                                                <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                                            </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <DockPanel Grid.Row="6" Margin="0,8,0,0">
                            <Button Content="Check Shown Views" Width="120" Height="24" Click="button_check_all_views"/>
                            <Button Content="Uncheck Shown Views" Width="136" Height="24" Margin="6,0,0,0" Click="button_uncheck_all_views"/>
                            <Button Content="Invert Shown Views" Width="126" Height="24" Margin="6,0,0,0" Click="button_invert_shown_views"/>
                        </DockPanel>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="3" Width="4"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource panel_separator}"
                              Cursor="SizeWE"
                              DragCompleted="panel_splitter_drag_completed"/>

                <Border Grid.Column="4" Margin="4,8,8,8"
                        Background="{StaticResource bg2}"
                        BorderBrush="{StaticResource border_panel}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2.0*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.4*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="LINK SELECTION"
                                       Foreground="{StaticResource text_cyan}"
                                       FontWeight="Bold" FontSize="11"/>
                            <TextBlock x:Name="UI_link_count"
                                       Foreground="White" FontSize="11" Margin="8,0,0,0"
                                       Text="(0 selected)"/>
                        </DockPanel>

                        <DockPanel Grid.Row="1" Margin="0,0,0,6">
                            <TextBox x:Name="UI_link_filter" Height="26" Width="240"
                                     ToolTip="Filter links by name"
                                     TextChanged="link_filter_text_changed"/>
                        </DockPanel>

                        <ListBox Grid.Row="2" x:Name="UI_link_list">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}"
                                              Tag="{Binding}"
                                              Click="link_checkbox_click"
                                              Margin="2,1,2,1">
                                        <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <DockPanel Grid.Row="3" Margin="0,8,0,8">
                            <Button Content="Select Architectural" Width="126" Height="24" Click="button_select_arch_links"/>
                            <Button Content="Select All" Width="78" Height="24" Margin="6,0,0,0" Click="button_select_all_links"/>
                            <Button Content="Clear" Width="58" Height="24" Margin="6,0,0,0" Click="button_clear_link_selection"/>
                        </DockPanel>

                        <TextBox Grid.Row="4" x:Name="UI_log"
                                 IsReadOnly="True"
                                 Background="#243832"
                                 Foreground="#f4f7ef"
                                 BorderBrush="{StaticResource border_secondary}"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"
                                 Text="Ready. Select sheets and links to begin."/>

                        <TextBlock Grid.Row="5" x:Name="UI_feedback"
                                   Foreground="{StaticResource text_dim}" FontSize="11"
                                   Text="No changes applied yet."
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource header_background}" CornerRadius="0,0,10,10">
                <DockPanel Margin="12,4,12,4">
                    <TextBlock x:Name="UI_status_bar"
                               Foreground="{StaticResource text_dim}" FontSize="10"
                               Text="Tip: Shift-click sheets for a range, Alt-click for all shown, or use Typical Sheet Format for the standard linked-view workflow."/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>