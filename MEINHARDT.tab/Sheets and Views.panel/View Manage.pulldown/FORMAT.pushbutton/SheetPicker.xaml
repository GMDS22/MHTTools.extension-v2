<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Sheets"
    Height="640"
    Width="900"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#0b1a2b"
    Foreground="White">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select Sheets (grouped like Project Browser)"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,0,0,8"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="Search:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="UI_search"
                     Height="28"
                     Background="#0b1a2b"
                     Foreground="White"
                     BorderBrush="#35506f"
                     BorderThickness="1"
                     Padding="6,4"
                     VerticalAlignment="Center"
                     TextChanged="search_textbox_changed"/>
        </DockPanel>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#35506f" CornerRadius="4" Padding="6">
            <TreeView x:Name="UI_tree_sheets" Background="#10243a" BorderThickness="0" Foreground="White">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Height="Auto">
                            <CheckBox x:Name="SheetCheck"
                                      Content="{Binding Name}"
                                      IsChecked="{Binding IsChecked}"
                                      Tag="{Binding}"
                                      Click="sheet_checkbox_click"
                                      Foreground="White"
                                      Visibility="Collapsed"/>
                            <CheckBox x:Name="GroupCheck"
                                      Content="{Binding Name}"
                                      IsChecked="{Binding GroupCheckState}"
                                      IsThreeState="True"
                                      Tag="{Binding}"
                                      Click="sheet_checkbox_click"
                                      FontWeight="SemiBold"
                                      Foreground="#9ad7ff"
                                      Visibility="Visible"/>
                        </Grid>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSheet}" Value="True">
                                <Setter TargetName="SheetCheck" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="GroupCheck" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
            <TextBlock x:Name="UI_selected_count"
                       Text="Selected: 0"
                       Foreground="#9ad7ff"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>

                <Button Content="Check Shown"
                    Width="100"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="button_check_all"/>
                <Button Content="Uncheck Shown"
                    Width="100"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="button_uncheck_all"/>

            <Button Content="Cancel"
                    Width="100"
                    Height="28"
                    Margin="8,0,0,0"
                    DockPanel.Dock="Right"
                    Click="button_cancel"/>
            <Button Content="Use Selected Sheets"
                    Width="160"
                    Height="28"
                    DockPanel.Dock="Right"
                    Click="button_select"/>
        </DockPanel>
    </Grid>
</Window>
